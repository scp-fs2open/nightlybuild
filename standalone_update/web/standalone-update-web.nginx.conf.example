# Standalone Update Web UI — nginx reverse proxy config
#
# Setup:
#   1. Replace 'your.domain.example' with your actual domain
#   2. Copy this to your nginx config and symlink (see README)
#   3. Run: nginx -t && systemctl reload nginx
#   4. Run: certbot --nginx -d your.domain.example
#      (certbot will add the HTTPS server block and redirect automatically)

# General rate limit — prevents excessive polling or abuse of any endpoint
limit_req_zone $binary_remote_addr zone=standalone_update_general:10m rate=10r/s;
# Tight rate limit on login attempts to prevent brute force
limit_req_zone $binary_remote_addr zone=standalone_update_login:10m rate=5r/m;
# Limit concurrent WebSocket connections per IP
limit_conn_zone $binary_remote_addr zone=standalone_update_ws:10m;

server {
    listen 80;
    listen [::]:80;
    server_name your.domain.example;

    # Security headers
    add_header X-Frame-Options DENY;
    add_header X-Content-Type-Options nosniff;
    add_header Referrer-Policy strict-origin-when-cross-origin;
    add_header Content-Security-Policy "default-src 'self'; style-src 'self'; script-src 'self'; connect-src 'self'";

    # WebSocket support for Socket.IO
    location /socket.io/ {
        limit_conn standalone_update_ws 10;
        proxy_pass http://127.0.0.1:5000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade $http_upgrade;
        proxy_set_header Connection "upgrade";
        proxy_read_timeout 86400;
        proxy_send_timeout 86400;
    }

    location / {
        limit_req zone=standalone_update_general burst=20 nodelay;
        proxy_pass http://127.0.0.1:5000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }

    # Tight rate limit on login POST only
    location = /login {
        limit_req zone=standalone_update_login burst=5 nodelay;
        proxy_pass http://127.0.0.1:5000;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
    }
}
