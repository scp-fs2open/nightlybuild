#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
ENV_FILE="${SCRIPT_DIR}/standalone-update-web.env"

if [ ! -f "${ENV_FILE}" ]; then
    echo "ERROR: ${ENV_FILE} not found." >&2
    echo "Copy standalone-update-web.env.example to standalone-update-web.env and configure it." >&2
    exit 1
fi

set -a
. "${ENV_FILE}"
set +a

BIND="${WEB_HOST:-127.0.0.1}:${WEB_PORT:-5000}"

CMD=("${SCRIPT_DIR}/venv/bin/gunicorn" --bind "${BIND}" --workers 1 --worker-class eventlet --access-logfile -)
if [ "${GUNICORN_RELOAD:-0}" = "1" ]; then
    CMD+=(--reload)
fi
CMD+=(server:app)

exec "${CMD[@]}"
