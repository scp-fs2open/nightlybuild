WEB_HOST=127.0.0.1
WEB_PORT=5000
UPDATE_LOG_PATH=/home/scpuser/standalone_update.log
LOG_LINES=100
# generate with: $ python3 -c "import secrets; print(secrets.token_hex(32))"
# Regenerating this value will immediately invalidate all active sessions (useful
# if credentials are compromised and you need to force-logout all users).
SECRET_KEY=change-me
# generate with: $ python3 -c "from werkzeug.security import generate_password_hash; print(generate_password_hash('yourpassword'))"
# MAINTAIN THE SINGLE QUOTES AROUND THE HASH
PASSWORD_HASH='change-me'
# Set to 1 when serving over HTTPS to mark cookies as Secure (browsers will
# refuse to send them over plain HTTP, so leave at 0 for HTTP-only setups)
SECURE_COOKIES=0
# Set to 1 to enable gunicorn auto-reload on file changes (for local dev)
GUNICORN_RELOAD=0
